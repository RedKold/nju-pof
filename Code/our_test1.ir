FUNCTION main:
READ t2
t1 := t2
IF t3 != #0 GOTO label1
GOTO label2
LABEL label1:
t5 := #1
ARG t5
WRITE t5
t4 := t5
GOTO label3
LABEL label2:
IF t6 != #0 GOTO label4
GOTO label5
LABEL label4:
t9 := #1
t8 := #0 - t9
ARG t8
WRITE t8
t7 := t8
GOTO label6
LABEL label5:
t11 := #0
ARG t11
WRITE t11
t10 := t11
LABEL label6:
LABEL label3:
t12 := #0
RETURN t12
